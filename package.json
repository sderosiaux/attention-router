{
  "name": "attention-router",
  "version": "0.2.0",
  "description": "Local attention router for parallel coding agents",
  "type": "module",
  "bin": {
    "attn": "./bin/attn.mjs",
    "attn-mcp": "./bin/attn-mcp.mjs"
  },
  "scripts": {
    "build": "tsc",
    "test": "AR_LLM_MODE=mock tsc --noEmit && AR_LLM_MODE=mock node --test --import tsx tests/*.test.ts",
    "start": "tsx src/cli.ts start-server",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
